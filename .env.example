# =============================
# Runtime
# =============================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
# Number of cluster workers (default: min(CPU cores, 4)). Set to 1 to disable clustering.
WEB_CONCURRENCY=4
# Comma-separated list of allowed frontend origins (e.g. https://app.example.com,https://www.example.com)
ALLOWED_ORIGINS=

# =============================
# Security / Tokens
# =============================
ACCESS_TOKEN_SECRET=replace_with_strong_access_secret
REFRESH_TOKEN_SECRET=replace_with_strong_refresh_secret
# Optional legacy fallback used by a few modules
JWT_SECRET=replace_with_strong_jwt_secret
# Optional: if not set, JWT_SECRET is used as fallback
SEGMENT_VIEW_TOKEN_SECRET=

# =============================
# Database / Cache
# =============================
# Replace user/password with real credentials before starting the API
DATABASE_URL=postgresql://user:password@localhost:5432/carpooling?schema=public
# Connection pool sizing (default: max=25, min=5)
DB_POOL_MAX=25
DB_POOL_MIN=5
# Prefer REDIS_URL in production
REDIS_URL=redis://localhost:6379
# Optional fallback when REDIS_URL is not set
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================
# Mail
# =============================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Carpooling App <noreply@example.com>"

# =============================
# Public contact emails
# =============================
NEXT_PUBLIC_CONTACT_EMAIL=contact@deliivo.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@deliivo.com
NEXT_PUBLIC_LEGAL_EMAIL=legal@deliivo.com
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@deliivo.com
NEXT_PUBLIC_DEFAULT_LOCALE=en
# Web portal chat is intentionally disabled until the product supports chat in browser flows.
NEXT_PUBLIC_ENABLE_WEB_CHAT=false

# =============================
# Google Maps
# =============================
GOOGLE_MAPS_API_KEY=

# =============================
# Twilio SMS
# =============================
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
# Use at least one sender option:
TWILIO_PHONE_NUMBER=+10000000000
TWILIO_MESSAGING_SERVICE_SID=MGXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optional webhook for delivery status callbacks
TWILIO_STATUS_CALLBACK_URL=
# Must be false in production
SMS_MOCK_MODE=false
# Max allowed outbound SMS body length (Twilio hard limit is 1600)
SMS_MAX_BODY_LENGTH=1200
# BullMQ retry policy for SMS jobs
SMS_RETRY_ATTEMPTS=3
SMS_RETRY_BACKOFF_MS=2000
# Queue retention settings
SMS_QUEUE_REMOVE_ON_COMPLETE_COUNT=1000
SMS_QUEUE_REMOVE_ON_FAIL_COUNT=5000
# Worker throughput
SMS_WORKER_CONCURRENCY=5
# Keep false in production (OTP visible in response only for local debugging)
EXPOSE_OTP_IN_RESPONSE=false
# Optional: used by npm run test:twilio
TEST_SMS_TO=+10000000001

# =============================
# Stripe
# =============================
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Build-time publishable key for the web app. Use pk_test for test builds and pk_live for live builds.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
# Platform fee charged on top of booking price (percent, e.g. 10 = 10%). Set to 0 to disable.
PLATFORM_FEE_PERCENT=0
# Base URL of the frontend app — used in Stripe Connect return/refresh URLs
APP_BASE_URL=https://app.example.com

# =============================
# Booking payment mode
# =============================
# Default mode bypasses payment collection for booking flows.
# Set to stripe to route booking payments through Stripe.
BOOKING_PAYMENT_MODE=stripe
STRIPE_CONNECT_MOCK_MODE=false

# =============================
# AWS S3
# =============================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
AWS_S3_BUCKET_NAME=
AWS_S3_PUBLIC_BASE_URL=

# =============================
# Profile image storage
# =============================
# local = backend uploads folder, r2 = Cloudflare R2, aws = AWS S3
PROFILE_IMAGE_STORAGE_PROVIDER=local
PROFILE_IMAGE_MAX_SIZE_MB=5
PROFILE_IMAGE_ALLOWED_TYPES=image/jpeg,image/png,image/webp
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=deliivo-profile-images
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# Use your public R2 dev URL or custom domain, for example https://images.deliivo.com
R2_PUBLIC_BASE_URL=

# =============================
# Firebase (choose one method)
# =============================
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_SERVICE_ACCOUNT_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
# Browser Firebase Cloud Messaging config for web push. These NEXT_PUBLIC values
# are build-time values for the web container and come from Firebase project settings.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# =============================
# Pricing / Fuel defaults
# =============================
FUEL_EFFICIENCY_KM_PER_LITER=12
FUEL_PRICE_FETCH_TIMEOUT_MS=12000
FALLBACK_FUEL_PRICE_GB=1.5
FALLBACK_FUEL_PRICE_IN=95

# =============================
# Veriff (DL Verification)
# =============================
VERIFF_API_KEY=
VERIFF_SHARED_SECRET=
VERIFF_BASE_URL=https://stationapi.veriff.com/v1
# Public URL for Veriff to send webhook decisions (e.g. https://yourdomain.com/api/v1/dl-verification/webhook)
VERIFF_CALLBACK_URL=
# Development-only bypass flags. Keep false in production.
SKIP_DL_VERIFICATION=false
SKIP_VEHICLE_VERIFICATION=false
ALLOW_RIDE_SIMULATION=false
ALLOW_RIDE_MANUAL_OVERRIDE=false
NEXT_PUBLIC_ALLOW_RIDE_MANUAL_OVERRIDE=false
PUBLISH_CITY_POINT_RADIUS_METERS=15000
PUBLISH_STOPOVER_POINT_RADIUS_METERS=5000
NEXT_PUBLIC_PUBLISH_CITY_POINT_RADIUS_KM=15
NEXT_PUBLIC_PUBLISH_STOPOVER_POINT_RADIUS_KM=5
