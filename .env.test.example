# =========================================================
# .env.test — Environment variables for E2E test runs
# Copy to .env.test and fill in values before running:
#   cp .env.test.example .env.test
#   npm run test:e2e
# =========================================================

# ── Server ────────────────────────────────────────────────
NODE_ENV=test
PORT=3000

# URL the e2e runner uses to reach the running server.
# Must match the PORT above (or wherever the server is listening).
E2E_BASE_URL=http://localhost:3000

# ── REQUIRED for e2e ──────────────────────────────────────
# Exposes the OTP code in the signup/login API response so
# the test setup can verify emails without a real mail server.
# NEVER set this to true in production.
EXPOSE_OTP_IN_RESPONSE=true

# ── Database ──────────────────────────────────────────────
# Point at a dedicated test database to avoid polluting production data.
# The globalSetup creates test users; globalTeardown deletes them.
DATABASE_URL=postgresql://user:password@localhost:5432/carpooling_test?schema=public

# ── Cache ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=test_access_secret_at_least_32_chars_long
REFRESH_TOKEN_SECRET=test_refresh_secret_at_least_32_chars_long
JWT_SECRET=test_jwt_secret_at_least_32_chars_long

# ── Payments ──────────────────────────────────────────────
# Use bypass mode so tests don't hit real Stripe.
BOOKING_PAYMENT_MODE=bypass
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
PLATFORM_FEE_PERCENT=0

# ── Google Maps ──────────────────────────────────────────
# REQUIRED for full e2e coverage. Without this key, publish-ride
# and search tests that depend on route computation will be skipped.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Veriff (DL Verification) ─────────────────────────────
# Optional. Without these, DL verification tests verify endpoint
# contracts only (reject invalid requests) without full Veriff flow.
VERIFF_API_KEY=
VERIFF_SHARED_SECRET=
VERIFF_BASE_URL=https://stationapi.veriff.com/v1

# ── Rate limiting ────────────────────────────────────────
# Disable rate limiting in test to avoid 429s during parallel test runs
DISABLE_RATE_LIMIT=true

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Mocked external services ──────────────────────────────
SMS_MOCK_MODE=true
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=eu-north-1
AWS_S3_BUCKET_NAME=test-bucket
